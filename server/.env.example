# Database - Configuración para base de datos externa
# Formato: postgresql://[usuario]:[contraseña]@[host]:[puerto]/[nombre_bd]?schema=public
# Ejemplo: postgresql://gdi_user:mypassword@db.example.com:5432/gdi_production?schema=public
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# MongoDB - Conexión para módulo de encuestas/diagnósticos
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/surveyjs_db?retryWrites=true&w=majority"

# Client
CLIENT_URL="http://localhost:5173"

# AWS S3 - Almacenamiento de archivos
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_DEFAULT_REGION="us-east-2"
AWS_BUCKET="your-bucket-name"
AWS_USE_PATH_STYLE_ENDPOINT="true"

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=GDI
MAIL_FROM_EMAIL=noreply@gdi.com
