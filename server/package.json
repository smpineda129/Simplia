{
  "name": "gdi-server",
  "version": "1.0.0",
  "description": "Backend Node.js + Express + PostgreSQL",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prisma:migrate": "node_modules/.bin/prisma migrate dev",
    "prisma:generate": "node_modules/.bin/prisma generate",
    "prisma:push": "node_modules/.bin/prisma db push --accept-data-loss",
    "prisma:studio": "node_modules/.bin/prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "build": "npm install && npm run prisma:generate && node fix-duplicate-emails.js && npm run prisma:push"
  },
  "keywords": [
    "express",
    "nodejs",
    "postgresql",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@prisma/client": "5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.15.0",
    "pptxgenjs": "^4.0.1",
    "resend": "^6.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "5.12.1",
    "supertest": "^7.0.0"
  }
}
